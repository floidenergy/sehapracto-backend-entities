{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "target": "ESNext",
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"]
}
